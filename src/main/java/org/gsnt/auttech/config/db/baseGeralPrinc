GRANT CREATE, CONNECT ON DATABASE "BaseGeralPrinc" TO gilberto;

GRANT CONNECT ON DATABASE "BaseGeralPrinc" TO usuario_base;


/* >>>>> Tabela Cliente <<<<< */

/* ok */

CREATE SEQUENCE IF NOT EXISTS pvt.sqcodcliente
    INCREMENT 1
    START 1
    MINVALUE 1
    MAXVALUE 9223372036854775807
    CACHE 1;

ALTER SEQUENCE pvt.sqcodcliente
    OWNER TO "gilberto";

CREATE TABLE IF NOT EXISTS pvt.tabcliente
(
    cod bigint NOT NULL DEFAULT nextval('sqcodcliente'::regclass),
    cnpj character varying(19) COLLATE pg_catalog."default",
    cpf character varying(15) COLLATE pg_catalog."default",
    rg character varying(15) COLLATE pg_catalog."default",
    nome character varying(180) COLLATE pg_catalog."default" NOT NULL,
    apelido character varying(180) COLLATE pg_catalog."default",
    dataini date,
    status boolean NOT NULL DEFAULT false,
    inscr character varying(15) COLLATE pg_catalog."default",
    "inscrMun" character varying(15) COLLATE pg_catalog."default",
    perfil boolean,
    datacad date,
    tipo "char",
    CONSTRAINT tabcliente_pkey PRIMARY KEY (cod)
)

TABLESPACE pg_default;

ALTER TABLE IF EXISTS pvt.tabcliente
    OWNER to gilberto;

REVOKE ALL ON TABLE pvt.tabcliente FROM usuario_base;

GRANT ALL ON TABLE pvt.tabcliente TO gilberto;

GRANT DELETE, UPDATE, INSERT, SELECT ON TABLE pvt.tabcliente TO usuario_base;
-- Index: idx_tabcliente_cnpj

-- DROP INDEX IF EXISTS public.idx_tabcliente_cnpj;

CREATE INDEX IF NOT EXISTS idx_tabcliente_cnpj
    ON pvt.tabcliente USING btree
    (cnpj COLLATE pg_catalog."default" ASC NULLS LAST)
    TABLESPACE pg_default;
-- Index: idx_tabcliente_cpf

-- DROP INDEX IF EXISTS public.idx_tabcliente_cpf;

CREATE INDEX IF NOT EXISTS idx_tabcliente_cpf
    ON pvt.tabcliente USING btree
    (cpf COLLATE pg_catalog."default" ASC NULLS LAST)
    TABLESPACE pg_default;


