-- FUNCTION: public.fn_cliente_por_cnpj(text)

-- DROP FUNCTION IF EXISTS public.fn_cliente_por_cnpj(text);

CREATE OR REPLACE FUNCTION public.fn_cliente_por_cnpj(
	p_cnpj text)
    RETURNS TABLE(cod integer, nome text)
    LANGUAGE 'sql'
    COST 100
    STABLE PARALLEL UNSAFE
    ROWS 1000

AS $BODY$
    SELECT cod, nome
    FROM pvt.tabcliente
    WHERE cnpj = p_cnpj;
$BODY$;

ALTER FUNCTION public.fn_cliente_por_cnpj(text)
    OWNER TO gilberto;


GRANT EXECUTE ON FUNCTION public.fn_cliente_por_cnpj(text) TO gilberto;

GRANT EXECUTE ON FUNCTION public.fn_cliente_por_cnpj(text) TO usuario_base;

REVOKE EXECUTE ON FUNCTION public.fn_cliente_por_cnpj(text) from PUBLIC;

REVOKE EXECUTE ON FUNCTION public.fn_cliente_por_cnpj(text) from postgres;